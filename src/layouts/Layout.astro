---
import "@/styles/globals.css";
import { ToastContainer } from "react-toastify";
import { PWAUpdatePrompt } from "@/components/PWAUpdatePrompt";
// @ts-ignore
import { pwaInfo } from "virtual:pwa-info";

export interface Props {
    className?: string;
}

const { className } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1, viewport-fit=cover"
        />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico" />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/apple-touch-icon.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href="/favicon-32x32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href="/favicon-16x16.png"
        />

        <!-- PWA / standalone-app metas. iOS doesn't read the
             manifest's `theme_color` / `display`, so we mirror them
             via these older Apple-specific meta tags so the app
             launches full-screen with the right status-bar tint when
             installed from the Home Screen. The viewport-fit=cover
             above pairs with `env(safe-area-inset-*)` styles so notch
             devices use the full screen too. -->
        <meta name="theme-color" content="#DC3D38" />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta
            name="apple-mobile-web-app-status-bar-style"
            content="black-translucent"
        />
        <meta name="apple-mobile-web-app-title" content="Hide+Seek" />
        <meta name="mobile-web-app-capable" content="yes" />
        <meta name="application-name" content="Hide+Seek" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Inter+Tight:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,500;1,600;1,700;1,800;1,900&display=swap"
            rel="stylesheet"
        />
        <script
            type="text/partytown"
            async
            src="https://www.googletagmanager.com/gtag/js?id=G-RKJ9G6CNC2"
        ></script>
        <script type="text/partytown">
            window.dataLayer = window.dataLayer || [];
            function gtag() {
                dataLayer.push(arguments);
            }
            gtag("js", new Date());

            gtag("config", "G-RKJ9G6CNC2");
        </script>
        <script type="text/javascript">
            if (!window.location.host.includes("localhost")) {
                (function (c, l, a, r, i, t, y) {
                    c[a] =
                        c[a] ||
                        function () {
                            (c[a].q = c[a].q || []).push(arguments);
                        };
                    t = l.createElement(r);
                    t.async = 1;
                    t.src = "https://www.clarity.ms/tag/" + i;
                    y = l.getElementsByTagName(r)[0];
                    y.parentNode.insertBefore(t, y);
                })(window, document, "clarity", "script", "sus45mfdvm");
            }
        </script>
        <meta name="generator" content={Astro.generator} />
        <!-- HTML Meta Tags -->
        <title>Map Generator for Jet Lag The Game: Hide and Seek</title>
        <meta
            name="description"
            content="Automatically generate maps for Jet Lag The Game: Hide and Seek with ease! Simply name the questions and watch the map eliminate hundreds of possibilities in seconds."
        />

        <!-- Facebook Meta Tags -->
        <meta
            property="og:url"
            content="https://taibeled.github.io/JetLagHideAndSeek/"
        />
        <meta property="og:type" content="website" />
        <meta
            property="og:title"
            content="Map Generator for Jet Lag The Game: Hide and Seek"
        />
        <meta
            property="og:description"
            content="Automatically generate maps for Jet Lag The Game: Hide and Seek with ease! Simply name the questions and watch the map eliminate hundreds of possibilities in seconds."
        />
        <meta
            property="og:image"
            content="https://taibeled.github.io/JetLagHideAndSeek/JLIcon.png"
        />

        <!-- Twitter Meta Tags -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta property="twitter:domain" content="taibeled.github.io" />
        <meta
            property="twitter:url"
            content="https://taibeled.github.io/JetLagHideAndSeek/"
        />
        <meta
            name="twitter:title"
            content="Map Generator for Jet Lag The Game: Hide and Seek"
        />
        <meta
            name="twitter:description"
            content="Automatically generate maps for Jet Lag The Game: Hide and Seek with ease! Simply name the questions and watch the map eliminate hundreds of possibilities in seconds."
        />
        <meta
            name="twitter:image"
            content="https://taibeled.github.io/JetLagHideAndSeek/JLIcon.png"
        />

        {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
    </head>
    <body class:list={[className, "dark"]}>
        <slot />
        <ToastContainer client:only />
        <PWAUpdatePrompt client:only="react" />
    </body>
</html>
