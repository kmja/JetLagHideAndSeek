---
import "@/styles/globals.css";
import { ToastContainer } from "react-toastify";
import { PWAUpdatePrompt } from "@/components/PWAUpdatePrompt";
// @ts-ignore
import { pwaInfo } from "virtual:pwa-info";

export interface Props {
    className?: string;
}

const { className } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1, viewport-fit=cover"
        />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico" />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/apple-touch-icon.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href="/favicon-32x32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href="/favicon-16x16.png"
        />

        <!-- PWA / standalone-app metas. iOS doesn't read the
             manifest's `theme_color` / `display`, so we mirror them
             via these older Apple-specific meta tags so the app
             launches full-screen with the right status-bar tint when
             installed from the Home Screen. The viewport-fit=cover
             above pairs with `env(safe-area-inset-*)` styles so notch
             devices use the full screen too. -->
        <meta name="theme-color" content="#DC3D38" />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta
            name="apple-mobile-web-app-status-bar-style"
            content="black-translucent"
        />
        <meta name="apple-mobile-web-app-title" content="Hide+Seek" />
        <meta name="mobile-web-app-capable" content="yes" />
        <meta name="application-name" content="Hide+Seek" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Inter+Tight:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,500;1,600;1,700;1,800;1,900&display=swap"
            rel="stylesheet"
        />
        <script
            type="text/partytown"
            async
            src="https://www.googletagmanager.com/gtag/js?id=G-RKJ9G6CNC2"
        ></script>
        <script type="text/partytown">
            window.dataLayer = window.dataLayer || [];
            function gtag() {
                dataLayer.push(arguments);
            }
            gtag("js", new Date());

            gtag("config", "G-RKJ9G6CNC2");
        </script>
        <script type="text/javascript">
            if (!window.location.host.includes("localhost")) {
                (function (c, l, a, r, i, t, y) {
                    c[a] =
                        c[a] ||
                        function () {
                            (c[a].q = c[a].q || []).push(arguments);
                        };
                    t = l.createElement(r);
                    t.async = 1;
                    t.src = "https://www.clarity.ms/tag/" + i;
                    y = l.getElementsByTagName(r)[0];
                    y.parentNode.insertBefore(t, y);
                })(window, document, "clarity", "script", "sus45mfdvm");
            }
        </script>
        <meta name="generator" content={Astro.generator} />
        <!-- HTML Meta Tags -->
        <title>Map Generator for Jet Lag The Game: Hide and Seek</title>
        <meta
            name="description"
            content="Automatically generate maps for Jet Lag The Game: Hide and Seek with ease! Simply name the questions and watch the map eliminate hundreds of possibilities in seconds."
        />

        <!-- Facebook Meta Tags -->
        <meta
            property="og:url"
            content="https://taibeled.github.io/JetLagHideAndSeek/"
        />
        <meta property="og:type" content="website" />
        <meta
            property="og:title"
            content="Map Generator for Jet Lag The Game: Hide and Seek"
        />
        <meta
            property="og:description"
            content="Automatically generate maps for Jet Lag The Game: Hide and Seek with ease! Simply name the questions and watch the map eliminate hundreds of possibilities in seconds."
        />
        <meta
            property="og:image"
            content="https://taibeled.github.io/JetLagHideAndSeek/JLIcon.png"
        />

        <!-- Twitter Meta Tags -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta property="twitter:domain" content="taibeled.github.io" />
        <meta
            property="twitter:url"
            content="https://taibeled.github.io/JetLagHideAndSeek/"
        />
        <meta
            name="twitter:title"
            content="Map Generator for Jet Lag The Game: Hide and Seek"
        />
        <meta
            name="twitter:description"
            content="Automatically generate maps for Jet Lag The Game: Hide and Seek with ease! Simply name the questions and watch the map eliminate hundreds of possibilities in seconds."
        />
        <meta
            name="twitter:image"
            content="https://taibeled.github.io/JetLagHideAndSeek/JLIcon.png"
        />

        {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}

        <!--
          GPS spoof for local development. Lets you test GPS-dependent
          flows (the wizard's auto-locate, thermometer live distance,
          hider position pin) without a real device. Runs only when
          serving from localhost AND the user has explicitly set the
          `__jlhs_gpsSpoof` localStorage key. Production deploys
          never trip this.

          Two schemas supported:

          (A) Single-position spoof — every call to navigator.geolocation
              returns the same simulated walker, regardless of role:

            localStorage.setItem('__jlhs_gpsSpoof', JSON.stringify({
              centerLat: 59.3293, centerLng: 18.0686,
              radiusM: 500, speedMps: 1.39,
            }));
            location.reload();

          (B) Role-aware spoof — when `playerRole` is "seeker" the
              spoof returns the seeker's simulated position, when
              "hider" it returns the hider's. Lets you switch sides
              via the debug panel's "→ Seeker / → Hider" buttons and
              get the matching GPS without re-configuring:

            localStorage.setItem('__jlhs_gpsSpoof', JSON.stringify({
              seeker: { centerLat: 59.3303, centerLng: 18.0593,
                        radiusM: 800, speedMps: 1.39 },
              hider:  { centerLat: 59.3169, centerLng: 18.0626,
                        radiusM: 100, speedMps: 0.5 },
            }));
            location.reload();

          To disable either:
            localStorage.removeItem('__jlhs_gpsSpoof');
            location.reload();
        -->
        <script is:inline>
            (function () {
                if (
                    !/^(localhost|127\.0\.0\.1|\[::1\])$/.test(
                        window.location.hostname,
                    )
                )
                    return;
                let cfg;
                try {
                    cfg = JSON.parse(localStorage.getItem("__jlhs_gpsSpoof"));
                } catch (e) {
                    return;
                }
                if (!cfg || typeof cfg !== "object") return;

                const buildWalker = function (entry) {
                    if (!entry || typeof entry !== "object") return null;
                    const CENTER = {
                        lat: Number(entry.centerLat),
                        lng: Number(entry.centerLng),
                    };
                    if (
                        !Number.isFinite(CENTER.lat) ||
                        !Number.isFinite(CENTER.lng)
                    )
                        return null;
                    const RADIUS_M = Number(entry.radiusM) || 500;
                    // Speed of 0 means "stationary" — the position
                    // stays clamped to the eastern edge of the (zero-
                    // radius) circle. Used for "hider sitting still
                    // at their hiding spot" scenarios.
                    const SPEED_MPS = Number.isFinite(Number(entry.speedMps))
                        ? Number(entry.speedMps)
                        : 1.39;
                    const M_PER_DEG_LAT = 111000;
                    const M_PER_DEG_LNG =
                        111000 * Math.cos((CENTER.lat * Math.PI) / 180);
                    const RADIUS_DEG_LAT = RADIUS_M / M_PER_DEG_LAT;
                    const RADIUS_DEG_LNG = RADIUS_M / M_PER_DEG_LNG;
                    const OMEGA =
                        RADIUS_M > 0 && SPEED_MPS > 0
                            ? SPEED_MPS / RADIUS_M
                            : 0;
                    const start = Date.now();
                    return {
                        center: CENTER,
                        radiusMeters: RADIUS_M,
                        speedMps: SPEED_MPS,
                        positionAt: function (when) {
                            const elapsed = (when - start) / 1000;
                            const angle = OMEGA * elapsed;
                            return {
                                coords: {
                                    latitude:
                                        CENTER.lat +
                                        RADIUS_DEG_LAT * Math.cos(angle),
                                    longitude:
                                        CENTER.lng +
                                        RADIUS_DEG_LNG * Math.sin(angle),
                                    heading:
                                        ((((angle * 180) / Math.PI + 90) %
                                            360) +
                                            360) %
                                        360,
                                    accuracy: 12,
                                    altitude: 22,
                                    altitudeAccuracy: 5,
                                    speed: SPEED_MPS,
                                },
                                timestamp: when,
                            };
                        },
                    };
                };

                // Detect schema. If the config has `seeker` and/or
                // `hider` keys, it's role-aware; otherwise treat the
                // whole object as a single-position config.
                const seekerWalker = cfg.seeker
                    ? buildWalker(cfg.seeker)
                    : null;
                const hiderWalker = cfg.hider ? buildWalker(cfg.hider) : null;
                const singleWalker =
                    !seekerWalker && !hiderWalker ? buildWalker(cfg) : null;

                if (!seekerWalker && !hiderWalker && !singleWalker) return;

                // Read the persisted role from localStorage. Default
                // role is "seeker" so the seeker-side flows work even
                // before the wizard has been touched. Be defensive:
                // persistentAtom may store the value JSON-quoted or
                // raw depending on the encode option.
                const readRole = function () {
                    const raw = localStorage.getItem("playerRole");
                    if (!raw) return "seeker";
                    try {
                        const parsed = JSON.parse(raw);
                        if (parsed === "hider") return "hider";
                        if (parsed === "seeker") return "seeker";
                    } catch (e) {}
                    if (raw === "hider" || raw === '"hider"') return "hider";
                    return "seeker";
                };

                const positionFor = function (when) {
                    const role = readRole();
                    const walker =
                        role === "hider"
                            ? hiderWalker || singleWalker || seekerWalker
                            : seekerWalker || singleWalker || hiderWalker;
                    return walker.positionAt(when);
                };

                const watchIntervals = new Map();
                let nextWatchId = 9000;

                Object.defineProperty(navigator.geolocation, "getCurrentPosition", {
                    value: function (success) {
                        setTimeout(function () {
                            success(positionFor(Date.now()));
                        }, 80);
                    },
                    configurable: true,
                    writable: true,
                });
                Object.defineProperty(navigator.geolocation, "watchPosition", {
                    value: function (success) {
                        const id = nextWatchId++;
                        setTimeout(function () {
                            success(positionFor(Date.now()));
                        }, 80);
                        const handle = setInterval(function () {
                            success(positionFor(Date.now()));
                        }, 2000);
                        watchIntervals.set(id, handle);
                        return id;
                    },
                    configurable: true,
                    writable: true,
                });
                Object.defineProperty(navigator.geolocation, "clearWatch", {
                    value: function (id) {
                        const h = watchIntervals.get(id);
                        if (h !== undefined) {
                            clearInterval(h);
                            watchIntervals.delete(id);
                        }
                    },
                    configurable: true,
                    writable: true,
                });

                if (navigator.permissions && navigator.permissions.query) {
                    const orig = navigator.permissions.query.bind(
                        navigator.permissions,
                    );
                    Object.defineProperty(navigator.permissions, "query", {
                        value: function (d) {
                            if (d && d.name === "geolocation") {
                                return Promise.resolve({
                                    state: "granted",
                                    onchange: null,
                                    addEventListener: function () {},
                                    removeEventListener: function () {},
                                    dispatchEvent: function () {
                                        return false;
                                    },
                                });
                            }
                            return orig(d);
                        },
                        configurable: true,
                        writable: true,
                    });
                }

                window.__gpsSpoof = {
                    schema: seekerWalker || hiderWalker ? "role-aware" : "single",
                    seeker: seekerWalker,
                    hider: hiderWalker,
                    single: singleWalker,
                    positionFor: positionFor,
                    readRole: readRole,
                };

                console.log(
                    "[gpsSpoof] active — schema",
                    window.__gpsSpoof.schema,
                    seekerWalker
                        ? "seeker centre " + JSON.stringify(seekerWalker.center)
                        : "",
                    hiderWalker
                        ? "hider centre " + JSON.stringify(hiderWalker.center)
                        : "",
                    singleWalker
                        ? "single centre " + JSON.stringify(singleWalker.center)
                        : "",
                );
            })();
        </script>
    </head>
    <body class:list={[className, "dark"]}>
        <slot />
        {/* ToastContainer defaults: top-right at 3000ms autoClose.
            That position sits right under iOS Safari's notch and
            covers the Hider timer / Map options chip cluster. Bumping
            to top-center keeps it out of the way of those controls
            on mobile, and the 4 s autoClose covers a comfortable
            read window without lingering. `theme="dark"` matches the
            app's hardcoded dark mode so the toasts stop flashing
            light backgrounds. */}
        <ToastContainer
            client:only
            position="top-center"
            autoClose={4000}
            theme="dark"
            newestOnTop
            pauseOnFocusLoss={false}
            limit={4}
        />
        <PWAUpdatePrompt client:only="react" />
    </body>
</html>
