---
import Layout from "@/layouts/Layout.astro";
import { Map } from "@/components/Map";
import {
    SidebarProvider as SidebarProviderL,
    SidebarTrigger as SidebarTriggerL,
} from "@/components/ui/sidebar-l";
import {
    SidebarProvider as SidebarProviderR,
} from "@/components/ui/sidebar-r";
import { QuestionSidebar } from "@/components/QuestionSidebar";
import { ZoneSidebar } from "@/components/ZoneSidebar";
import { OptionDrawers } from "@/components/OptionDrawers";
import { BottomNav } from "@/components/BottomNav";
import { MapDisplayControls } from "@/components/MapDisplayControls";
import { GameSetupDialog } from "@/components/GameSetupDialog";
import { ThermometerOverlay } from "@/components/ThermometerOverlay";
import { AnswerLinkReader } from "@/components/AnswerLinkReader";
import { MapLoadingOverlay } from "@/components/MapLoadingOverlay";
import { HiderTimer } from "@/components/HiderTimer";
import { RolePicker } from "@/components/RolePicker";
---

<Layout className="bg-jetlag">
    <SidebarProviderL client:load>
        <SidebarProviderR client:load defaultOpen={false}>
            <QuestionSidebar client:only />
            <main class="flex flex-col flex-grow group">
                <div
                    class="flex justify-center"
                    id="map-modal-dialog-container-leaflet"
                >
                    <div class="w-full h-full relative">
                        <div
                            class="absolute top-[72px] md:top-2 left-2 z-[1030] group-[.fullscreen]:hidden hidden md:block"
                            data-tutorial-id="left-sidebar-trigger"
                        >
                            <SidebarTriggerL client:load />
                        </div>
                        {/* Persistent hider timer — top-left on mobile,
                            slightly inset on desktop next to the sidebar
                            trigger. Shows hiding-period countdown then
                            hidden-time elapsed once the period ends. */}
                        <div
                            class="absolute top-2 left-2 md:left-12 z-[1030] group-[.fullscreen]:hidden"
                        >
                            <HiderTimer client:only />
                        </div>
                        {/* Top-right cluster: zones trigger + satellite +
                            transit-lines toggles. Visible on both desktop
                            and mobile now — the bottom-nav slot that
                            previously held the zones trigger has been
                            reassigned to "Game". */}
                        <div
                            class="absolute top-2 right-2 z-[1030] group-[.fullscreen]:hidden"
                        >
                            <MapDisplayControls client:only />
                        </div>
                        <div
                            class="bottom-5 right-2 mx-auto mb-2 w-fit absolute z-[1030] group-[.fullscreen]:hidden hidden md:block"
                        >
                            <OptionDrawers client:load />
                        </div>
                        <ThermometerOverlay client:only />
                        <Map
                            className="w-full group-[.fullscreen]:w-full group-[.fullscreen]:h-full"
                            client:only
                        />
                        <MapLoadingOverlay client:only />
                    </div>
                </div>
            </main>
            <ZoneSidebar client:only />
            <BottomNav client:only />
            <GameSetupDialog client:only />
            <AnswerLinkReader client:only />
            <RolePicker client:only />
        </SidebarProviderR>
    </SidebarProviderL>
</Layout>
