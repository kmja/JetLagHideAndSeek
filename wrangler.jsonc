// Cloudflare Worker config for the JetLag Hide and Seek **frontend**.
//
// This is the public site at
// https://jetlaghideandseek.karl-mj-andersson.workers.dev — it serves
// the Vite-built static SPA bundle from `dist/` as Worker Static
// Assets. No server-side code is involved here; the multiplayer
// backend is a separate Worker (see `worker/wrangler.toml`).
//
// (Historical note: the app used to be Astro and this file guarded
// against the Cloudflare pipeline auto-adding the `@astrojs/cloudflare`
// SSR adapter. The app is now a plain Vite SPA — `vite build` emits a
// static `dist/` — so that concern is moot, but the explicit config
// is still what Workers Builds deploys.)
//
// `not_found_handling: "single-page-application"` makes Cloudflare
// fall back to `index.html` for client-routed paths so deep links
// (including the `/h` hider route, which React Router handles
// client-side) keep working.
{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "jetlaghideandseek",
    "compatibility_date": "2026-05-22",
    "observability": {
        "enabled": true
    },
    "assets": {
        "directory": "dist",
        "not_found_handling": "single-page-application"
    }
}
